# Django
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=cheguia.settings.dev

# Database
# When running via docker-compose, DB_HOST must be "db" (the service name).
# For local dev without Docker, use "localhost".
DB_NAME=paraguay_guide
DB_USER=cheguia
DB_PASSWORD=cheguia_dev
DB_HOST=db
DB_PORT=5432

# OpenAI
OPENAI_API_KEY=sk-...

# Production only (not needed for dev)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
