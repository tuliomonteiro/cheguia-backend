# Django
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=cheguia.settings.dev

# Database
# When running via docker-compose, DB_HOST must be "db" (the service name).
# For local dev without Docker, use "localhost".
DB_NAME=paraguay_guide
DB_USER=cheguia
DB_PASSWORD=cheguia_dev
DB_HOST=db
DB_PORT=5432

# AI provider — set to "openai" or "gemini"
AI_CHAT_PROVIDER=openai
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_PROVIDER=openai
AI_EMBEDDING_MODEL=text-embedding-3-small

# API keys — only the key for the active AI_CHAT_PROVIDER is required
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# Rate limiting (DRF throttle rates, format: <count>/<period>)
THROTTLE_ANON=30/min
THROTTLE_USER=120/min
THROTTLE_CHAT=15/min

# Backoffice (Django admin) mount path — pick something non-obvious in prod
DJANGO_ADMIN_URL=admin/

# Logging
LOG_LEVEL=INFO

# Error tracking — leave empty to disable Sentry entirely
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# Production only (not needed for dev)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
